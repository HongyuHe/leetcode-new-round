                <script>
                    jQuery(window).on('elementor/frontend/init', function () {
                        elementorFrontend.hooks.addAction('frontend/element_ready/related_posts.default', function ($scope, $) {
                            const carousel = $scope.find('.posts-carousel-69ef9a0be843c')[0];
                            if (!carousel) {
                                return;
                            }

                            if (!elementorFrontend.utils?.swiper) {
                                return;
                            }

                            carousel.querySelectorAll('.label-term[data-term-url]').forEach(function(label) {
                                label.style.cursor = 'pointer';
                                label.addEventListener('click', function(e) {
                                    e.preventDefault();
                                    e.stopPropagation();
                                    window.location.href = this.getAttribute('data-term-url');
                                });
                            });

                            setTimeout(() => {
                                const slidesCount = carousel.querySelectorAll('.swiper-slide').length;
                                const slidesPV = slidesCount > 3 ? 3 : slidesCount;
                                if (slidesCount === 1) {
                                    carousel.classList.add('single-slide');
                                } else if (slidesCount === 2) {
                                    carousel.classList.add('double-slide');
                                }

                                const SwiperInstance = elementorFrontend.utils.swiper;

                                new SwiperInstance(carousel, {
                                    loop: slidesCount > 3,
                                    slidesPerView: slidesPV,
                                    spaceBetween: 20,
                                    pagination: {
                                        el: carousel.querySelector('.swiper-pagination'),
                                        clickable: true,
                                    },
                                    breakpoints: {
                                        0: { slidesPerView: 1 },
                                        768: { slidesPerView: 2 },
                                        1040: { slidesPerView: 3 }
                                    }
                                });
                            }, 50);

                        });
                    });

                </script>
