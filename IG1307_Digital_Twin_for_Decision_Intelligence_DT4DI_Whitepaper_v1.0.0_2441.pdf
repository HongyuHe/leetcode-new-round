<!-- HubSpot Forms Embed Handler. (c) STC KG Dr. Heiko Tobias - 18.07.2025 -->
<script>
"use strict";
(function() {
    // Ausführung im WP-Admin oder Elementor-Editor unterbrechen:
    if (window.location.href.indexOf("wp-admin") !== -1 || window.location.search.indexOf("elementor") !== -1) {
        return; // Im Backend/Editor kein Formular-Laden durchführen
    }

    /** Hilfsfunktion: HubSpot Forms Script laden (falls noch nicht) und dann Callback ausführen */
    function ensureHubSpotScript(callback) {
        if (window.hbspt && window.hbspt.forms && window.hbspt.forms.create) {
            // Bibliothek schon vorhanden
            callback();
        } else {
            // Erstmaliger Ladevorgang
            if (!window._hsFormsLoading) {
                window._hsFormsLoading = true;
                window._hsFormsOnLoad = [];
                window._hsFormsOnLoad.push(callback);
                var hs = document.createElement("script");
                hs.src = "//js.hsforms.net/forms/v2.js";
                hs.type = "text/javascript";
                hs.charset = "utf-8";
                hs.onload = function() {
                    // Nach Laden: alle gespeicherten Callbacks ausführen
                    if (window._hsFormsOnLoad) {
                        window._hsFormsOnLoad.forEach(function(cb) {
                            try { cb(); } catch (e) { console.error("Fehler im HubSpot-Callback:", e); }
                        });
                        window._hsFormsOnLoad = null;
                    }
                };
                hs.onerror = function() {
                    console.error("HubSpot Form Script konnte nicht geladen werden.");
                };
                // Script ins Dokument einfügen (head oder body)
                var head = document.head || document.getElementsByTagName("head")[0] || document.documentElement;
                head.appendChild(hs);
            } else {
                // Bibliothek lädt bereits, Callback zur Warteschlange hinzufügen
                window._hsFormsOnLoad.push(callback);
            }
        }
    }

    /** Formular für einen Container laden, wenn noch nicht erfolgt */
    function loadHubSpotForm(container) {
        if (!container || container.getAttribute("data-form-loaded")) {
            return; // Keine Aktion nötig (nicht vorhanden oder schon geladen)
        }
        var portalId = container.getAttribute("data-portal-id") || "144333933"; 
        var formId = container.getAttribute("data-form-id");
        if (!formId || !portalId) {
            console.error("Fehlende formId oder portalId für HubSpot-Formular Container", container);
            return;
        }
        // Optional: Region auslesen, falls angegeben (z.B. "eu1" für EU-Portale)
        var region = container.getAttribute("data-region") || "eu1";
        // Prefill-Daten auslesen (z.B. "field1=wert1;field2=wert2")
        var prefillData = container.getAttribute("data-form-input");
        // Konfiguration für hbspt.forms.create zusammenstellen
        var formOptions = {
            portalId: portalId,
            formId: formId,
            target: "#" + (window.CSS && window.CSS.escape ? window.CSS.escape(container.id) : container.id),
            formInstanceId: container.id  // eindeutige Instanz-ID pro Container (wichtig bei mehrfacher Einbindung)
        };
        // Region nur setzen, wenn vorhanden
        if (region) {
            formOptions.region = region;
        }
        // onFormReady definieren, um Prefill-Werte zu setzen, falls vorhanden
        if (prefillData) {
            formOptions.onFormReady = function($form) {
                try {
                    // Prefill-String in einzelne Paare aufteilen und Felder befüllen
                    prefillData.split(";").forEach(function(pair) {
                        var kv = pair.split("=");
                        if (kv.length === 2) {
                            var name = kv[0].trim();
                            var val = kv[1].trim();
                            if (!name) return;
                            if ($form && typeof $form.find === "function") {
                                // jQuery vorhanden: $form ist ein jQuery-Objekt
                                var $field = $form.find('[name="' + name + '"]');
                                if ($field.length === 0) {
                                    // Falls nichts über name gefunden, alternativ über ID versuchen
                                    $field = $form.find("#" + (window.CSS && window.CSS.escape ? window.CSS.escape(name) : name));
                                }
                                if ($field.length > 0) {
                                    $field.val(val);
                                    $field.change(); // Change-Event auslösen (für HubSpot Logik)
                                }
                            } else {
                                // Kein jQuery: $form könnte ein DOM-Element sein
                                var formEl = $form && $form.nodeType ? $form : null;
                                if (formEl) {
                                    var selectorName = '[name="' + name + '"]';
                                    var selectorId = "#" + (window.CSS && window.CSS.escape ? window.CSS.escape(name) : name);
                                    var fieldEl = formEl.querySelector(selectorName) || formEl.querySelector(selectorId);
                                    if (fieldEl) {
                                        fieldEl.value = val;
                                        // Change-Event manuell erzeugen
                                        if (typeof Event === "function") {
                                            // Standard
                                            var changeEvent = new Event("change", { bubbles: true });
                                            fieldEl.dispatchEvent(changeEvent);
                                        } else if (document.createEvent) {
                                            // IE11
                                            var evt = document.createEvent("HTMLEvents");
                                            evt.initEvent("change", true, false);
                                            fieldEl.dispatchEvent(evt);
                                        } else if (fieldEl.fireEvent) {
                                            // IE<9 Fallback
                                            fieldEl.fireEvent("onchange");
                                        }
                                    }
                                }
                            }
                        }
                    });
                } catch (e) {
                    console.error("Fehler beim Prefill der HubSpot-Formularfelder:", e);
                }
            };
        }
        // Markieren, dass für diesen Container das Formular geladen wird
        container.setAttribute("data-form-loaded", "true");
        // Formular erstellen (hbspt.forms.create)
        try {
            window.hbspt.forms.create(formOptions);
        } catch (e) {
            console.error("HubSpot Form Embed Fehler:", e);
        }
    }

    /** Initiales Scannen aller vorhandenen Formular-Container */
    function initAllForms() {
        var containers = document.querySelectorAll('div[id^="hubspotForm"][data-form-id]');
        for (var i = 0; i < containers.length; i++) {
            var container = containers[i];
            if (!container.getAttribute("data-form-loaded")) {
                // Sicherstellen, dass HS-Script geladen ist, dann Formular laden
                ensureHubSpotScript(loadHubSpotForm.bind(null, container));
            }
        }
    }

    // Initialisierung beim DOM-Ready (mit Fallback für ältere Browser/IE)
    if (document.readyState !== "loading") {
        initAllForms();
    } else if (document.addEventListener) {
        document.addEventListener("DOMContentLoaded", initAllForms);
    } else if (document.attachEvent) {
        document.attachEvent("onreadystatechange", function() {
            if (document.readyState === "complete") {
                initAllForms();
            }
        });
    }

    // MutationObserver einrichten, um dynamisch hinzugefügte Formular-Container zu erkennen
    if (window.MutationObserver) {
        var observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                if (mutation.addedNodes) {
                    for (var i = 0; i < mutation.addedNodes.length; i++) {
                        var node = mutation.addedNodes[i];
                        if (node.nodeType !== 1) continue; // nur Elemente
                        // Prüfen, ob der hinzugefügte Node selbst ein Formular-Container ist
                        if (node.matches && node.matches('div[id^="hubspotForm"][data-form-id]')) {
                            if (!node.getAttribute("data-form-loaded")) {
                                ensureHubSpotScript(loadHubSpotForm.bind(null, node));
                            }
                        }
                        // Oder ob innerhalb des Nodes noch weitere passende Container liegen
                        if (node.querySelectorAll) {
                            var innerContainers = node.querySelectorAll('div[id^="hubspotForm"][data-form-id]');
                            for (var j = 0; j < innerContainers.length; j++) {
                                var inner = innerContainers[j];
                                if (!inner.getAttribute("data-form-loaded")) {
                                    ensureHubSpotScript(loadHubSpotForm.bind(null, inner));
                                }
                            }
                        }
                    }
                }
            });
        });
        observer.observe(document.body, { childList: true, subtree: true });
    }
})();
</script>

<template id="brlbs-cmpnt-cb-template-youtube-content-blocker">
 <div class="brlbs-cmpnt-container brlbs-cmpnt-content-blocker" data-borlabs-cookie-content-blocker-id="youtube-content-blocker" data-borlabs-cookie-content=""><div class="brlbs-cmpnt-cb-preset-c brlbs-cmpnt-cb-youtube"> <div class="brlbs-cmpnt-cb-thumbnail" style="background-image: url('https://www.detecon.com/wp-content/uploads/borlabs-cookie/1/brlbs-cb-youtube-main.png')"></div> <div class="brlbs-cmpnt-cb-main"> <div class="brlbs-cmpnt-cb-play-button"></div> <div class="brlbs-cmpnt-cb-content"> <p class="brlbs-cmpnt-cb-description">You are currently viewing a placeholder content from <strong>YouTube</strong>. To access the actual content, click the button below. Please note that doing so will share data with third-party providers.</p> <a class="brlbs-cmpnt-cb-provider-toggle" href="#" data-borlabs-cookie-show-provider-information role="button">More Information</a> </div> <div class="brlbs-cmpnt-cb-buttons"> <a class="brlbs-cmpnt-cb-btn" href="#" data-borlabs-cookie-unblock role="button">Unblock content</a> <a class="brlbs-cmpnt-cb-btn" href="#" data-borlabs-cookie-accept-service role="button" style="display: inherit">Accept required service and unblock content</a> </div> </div> </div></div>
</template>
<script>
(function () {
    const allBackgroundContainerYt = document.querySelectorAll('[data-brlbs-elementor-bg-video-yt="true"]:not(:has(.brlbs-cmpnt-content-blocker))');

    const getYouTubeId = url => (url.match(new RegExp("(?:youtube\.com\/(?:[^\/\n\s]+\/\S+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([a-zA-Z0-9_-]{11})")) || [])[1] || null;
    const getThumbnailBackgroundImageUrl = (videoContainer) => {
        const bgImageCss = window.getComputedStyle(videoContainer).backgroundImage;
        if (bgImageCss != null && bgImageCss.startsWith('url(')) {
            return bgImageCss;
        }
        const thumbnailQuality = 'hqdefault';
        if (thumbnailQuality === 'none' || videoContainer.dataset.settings == null) {
            return null;
        }
        const settings = JSON.parse(videoContainer.dataset.settings)
        if (settings == null || !settings.hasOwnProperty('background_video_link')) {
            return null;
        }
        const ytId = getYouTubeId(settings.background_video_link);
        if (ytId == null) {
            return null;
        }
        return 'url("https://www.detecon.com/wp-content/uploads/borlabs-cookie/1/yt_' + ytId + '_' + thumbnailQuality + '.jpg")';
    };

    const template = document.getElementById('brlbs-cmpnt-cb-template-youtube-content-blocker');
    for (let videoContainer of allBackgroundContainerYt) {
        const id = videoContainer.dataset.id
        if (videoContainer && template) {
            const videoEmbed = videoContainer.querySelector('.elementor-background-video-embed');
            const cb = template.content.cloneNode(true).querySelector('.brlbs-cmpnt-container');
            cb.dataset.borlabsCookieContent = '';
            if (videoEmbed.nextSibling) {
                videoEmbed.parentNode.insertBefore(cb, videoEmbed.nextSibling);
            } else {
                videoEmbed.parentNode.appendChild(cb);
            }

            const bgImageCss = getThumbnailBackgroundImageUrl(videoContainer);
            const thumb = cb.querySelector('.brlbs-cmpnt-cb-thumbnail')
            if (bgImageCss != null && thumb != null) {
                thumb.style.backgroundImage = bgImageCss;
            }
        }
    }
})();
</script>
</body>
</html>
