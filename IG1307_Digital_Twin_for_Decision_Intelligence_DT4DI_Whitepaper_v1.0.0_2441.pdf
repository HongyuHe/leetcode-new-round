                    color: #262933;
                    padding: 40px 32px;
                }

                #carousel-immersive .carousel-immersive-title-item {
                    cursor: pointer;
                    margin-bottom: 10px;
                }

                #carousel-immersive .carousel-immersive-title-item span {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    gap: 12px;
                    padding: 6px 12px;
                    border-radius: 4px;
                }
                #carousel-immersive .carousel-immersive-title-item span .title-text{
                    color:#262933;
                    font-family: "TeleNeo";
                    font-size: 20px;
                    font-style: normal;
                    font-weight: 500;
                    line-height: 120%; /* 24px */
                }
                #carousel-immersive .title-link {
                    display: inline-flex;
                    align-items: center;
                    gap: 0.5em;
                    text-decoration: none;
                    justify-content: space-between;
                    width: 100%;
                }

                #carousel-immersive .title-link .title-icon svg {
                    width: 1em;
                    height: 1em;
                    display: inline-block;
                }


                #carousel-immersive .carousel-immersive-title-item .title-icon svg {
                    width: 16px;
                    height: 16px;
                    flex-shrink: 0;
                }

                #carousel-immersive .carousel-immersive-title-item.active span {
                    background-color: #E83390;
                    color: white;
                }

                #carousel-immersive .carousel-immersive-title-item.active .arrow-path {
                    fill: white;
                }

                #carousel-immersive .carousel-immersive-progress {
                    display: flex;
                    gap: 6px;
                    width: 80%;
                    margin: 0 auto;
                }

                #carousel-immersive .progress-line {
                    flex-grow: 1;
                    height: 4px;
                    background-color: #AEAFB2;
                    opacity: 0.5;
                    border-radius: 2px;
                    transition: background-color 0.3s ease, opacity 0.3s ease;
                }

                #carousel-immersive .progress-line.active {
                    background-color: #E20074;
                    opacity: 1;
                }

                #carousel-immersive .carousel-immersive-title-list {
                    margin-bottom: 48px;
                }
                #carousel-immersive .carousel-immersive-nav .detecon-anchor{
                    color: var(--Semantic-Colors-Text-Magenta, #E20074);
                    font-family: "TeleNeo";
                    font-size: 20px;
                    font-style: italic;
                    font-weight: 500;
                    line-height: 120%; /* 24px */
                    margin-bottom: 20px;
                }
                #carousel-immersive .carousel-immersive-nav h2{
                    color: var(--Semantic-Colors-Text-Dark, #262933);
                    font-family: "TeleNeo";
