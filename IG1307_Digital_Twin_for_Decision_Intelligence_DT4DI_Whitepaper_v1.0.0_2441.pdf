				<div class="elementor-element elementor-element-51532e4e elementor-widget elementor-widget-html" data-id="51532e4e" data-element_type="widget" data-e-type="widget" data-widget_type="html.default">
					<style>
  #otp-navigation { display:flex; flex-direction:column; max-height:50vh; overflow-y:auto; }
  #otp-navigation a { display:block; padding:9px 14px; font-family:'TeleNeo','Helvetica Neue',Arial,sans-serif; font-size:1.00rem; font-weight:400; color:#262933; text-decoration:none; border-left:3px solid transparent; transition:all 0.15s ease; cursor:pointer; }
  #otp-navigation a:hover { color:#E20074; background:#fdf0f6; }
  #otp-navigation a.is-active { color:#E20074; font-weight:500; border-left-color:#E20074; }
  #otp-navigation::-webkit-scrollbar { width:3px; }
  #otp-navigation::-webkit-scrollbar-thumb { background:#d0d1d2; border-radius:2px; }
  .otp-arrow { display:none; text-align:center; line-height:0; margin-bottom:-1px; }
  .otp-arrow.is-open { display:block; }
  @media (max-width:767px) {
    .otp-trigger { width:100%; border-radius:0 !important; padding:14px 22px !important;
      box-shadow:0 0px 4px rgba(0,0,0,0.08) !important; justify-content:center; }
    .otp-flyout { width:100% !important; max-width:100% !important;
      border-radius:16px 16px 0 0 !important; max-height:55vh; }
    .otp-arrow { display:none !important; }
  }
/* === Trigger Bar: zwei Hälften bündig === */
.otp-trigger-bar {
  display: flex !important;
  flex-direction: row !important;
  gap: 0 !important;
  border-radius: 16px !important;
  overflow: hidden;
  --border-radius: 16px !important;
}

/* Kinder-Rundungen UND Shadows komplett entfernen */
.otp-trigger-bar > .otp-trigger,
.otp-trigger-bar > .otp-cta {
  --border-radius: 0 !important;
  border-radius: 0 !important;
  margin: 0 !important;
}

/* Trennlinie */
.otp-trigger-bar > .otp-trigger {
  border-right: 1px solid rgba(0,0,0,0.06);
}

@media (max-width:767px) {
  .otp-trigger-bar {
    border-radius: 0 !important;
    box-shadow: 0 1px 1px rgba(0,0,0,0.08) !important;
  }
  .otp-trigger-bar > .otp-trigger,
  .otp-trigger-bar > .otp-cta {
    flex: 1;
  }
  .elementor-49263 .elementor-element.elementor-element-7111dfc8 {
  border-radius: 16px !important;
}
.elementor-element-51082e71 {
  border-radius: 16px !important;
}
}
.elementor-element-29785486 > div:nth-child(1) > div:nth-child(1) > svg:nth-child(1) {
  top: 2px;
}
.elementor-element-678f9fed > div:nth-child(1) > div:nth-child(1) > svg:nth-child(1) {
  top: 1px;
}
/* === Firefox-Fix: Heading & Icon Margins im Trigger Bar bündig === */
.otp-trigger-bar .elementor-widget-heading,
.otp-trigger-bar .elementor-widget-icon,
.otp-trigger-bar .elementor-heading-title {
  margin: 0 !important;
}

/* Flex-Kinder sauber ausrichten, unabhängig von Elementor-Margins */
.otp-trigger-bar .otp-trigger,
.otp-trigger-bar .otp-cta {
  align-items: center !important;
  line-height: 1.2;
}

/* Subpixel-Snapping erzwingen (klassischer Firefox-Fix) */
.otp-trigger-bar .otp-trigger > *,
.otp-trigger-bar .otp-cta > * {
  transform: translateZ(0);
  backface-visibility: hidden;
}
</style>

<script>
(function() {
  'use strict';

  // =====================================================
  //  KONFIGURATION
  // =====================================================
  var CONFIG = {
    scrollOffset:      90,
    showAfterPx:       150,
    minHeadings:       2,
    headingTag:        '.detecon-anchor',
    retryDelay:        500,   // ms — Wartezeit falls DOM noch nicht ready
    maxRetries:        3,     // Max Versuche bei DOM-Scan
    useFetchFallback:  true,  // Heikos Fallback: Seite per fetch() laden
    contentSelectors: [
      '.elementor-widget-theme-post-content',
      'article .elementor-element',
      'main .elementor-section',
      'main .e-con',
      '.entry-content',
      '.elementor'
    ],
    // Bereiche die NICHT gescannt werden sollen
    excludeSelectors: [
      'header',
      'footer',
      '.elementor-location-header',
      '.elementor-location-footer',
      '.otp-widget',
      'nav',
      '.dialog-widget-content'
    ]
  };

  // =====================================================
  //  ELEMENTE
  // =====================================================
  var widget, flyout, trigger, closeBtn, nav, arrow;

  function cacheElements() {
    widget   = document.querySelector('.otp-widget');
    flyout   = document.querySelector('.otp-flyout');
    trigger  = document.querySelector('.otp-trigger');
    closeBtn = document.querySelector('.otp-close-btn');
    nav      = document.getElementById('otp-navigation');
    arrow    = document.querySelector('.otp-arrow');
  }

  // =====================================================
  //  H2s AUS DEM DOM LESEN
  // =====================================================
  function findHeadings() {
    // Content-Container finden
    var contentArea = null;
    for (var i = 0; i < CONFIG.contentSelectors.length; i++) {
      var el = document.querySelector(CONFIG.contentSelectors[i]);
      if (el) { contentArea = el; break; }
    }

    // Fallback: gesamtes document.body
    if (!contentArea) contentArea = document.body;

    var allH = contentArea.querySelectorAll(CONFIG.headingTag);
    var headings = [];

    allH.forEach(function(h) {
      // Prüfe ob Heading in einem ausgeschlossenen Bereich liegt
      var excluded = false;
      for (var j = 0; j < CONFIG.excludeSelectors.length; j++) {
        if (h.closest(CONFIG.excludeSelectors[j])) {
          excluded = true;
          break;
        }
      }
      if (!excluded && h.textContent.trim().length > 0) {
        headings.push(h);
      }
    });

    return headings;
  }

  // =====================================================
  //  FALLBACK: SEITE PER FETCH LADEN & H2s PARSEN
  //  (Heikos Ansatz: "über die URL zugreifen")
  // =====================================================
  function fetchHeadingsFromURL() {
    return fetch(window.location.href, {
      credentials: 'same-origin',
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(response) { return response.text(); })
    .then(function(html) {
      var parser = new DOMParser();
      var doc = parser.parseFromString(html, 'text/html');

      // Finde Content-Bereich im geparsten HTML
      var contentArea = null;
      for (var i = 0; i < CONFIG.contentSelectors.length; i++) {
        var el = doc.querySelector(CONFIG.contentSelectors[i]);
        if (el) { contentArea = el; break; }
      }
      if (!contentArea) contentArea = doc.body;

      var fetchedH2s = contentArea.querySelectorAll(CONFIG.headingTag);
      var results = [];
      fetchedH2s.forEach(function(h) {
        var excluded = false;
        for (var j = 0; j < CONFIG.excludeSelectors.length; j++) {
          if (h.closest(CONFIG.excludeSelectors[j])) { excluded = true; break; }
        }
        if (!excluded && h.textContent.trim().length > 0) {
          results.push(h.textContent.trim());
        }
      });
      return results;
    })
    .catch(function() { return []; });
  }

  // =====================================================
  //  LINKS GENERIEREN & IN NAV INJIZIEREN
  // =====================================================
  function buildNavLinks(headings) {
    if (!nav) return;
    nav.innerHTML = '';

    var links = [];
    headings.forEach(function(h, idx) {
      if (!h.id) h.id = 'otp-section-' + idx;

      var a = document.createElement('a');
      a.href = '#' + h.id;
      a.textContent = h.textContent.trim();
      a.addEventListener('click', function(e) {
        e.preventDefault();
        var target = document.getElementById(h.id);
        if (!target) return;
        var y = target.getBoundingClientRect().top
              + window.pageYOffset - CONFIG.scrollOffset;
        window.scrollTo({ top: y, behavior: 'smooth' });
        if (window.innerWidth < 768) closeFlyout();
      });
      nav.appendChild(a);
      links.push({ el: a, target: h });
    });

    return links;
  }

  // Fallback-Variante: Links aus Text-Strings (fetch-Ergebnis)
  // Matcht die Texte mit echten DOM-H2s
  function buildNavFromFetchedTexts(texts) {
    if (!nav) return [];
    nav.innerHTML = '';

    // Finde die echten DOM-H2s anhand der Texte
    var allDomH2s = document.querySelectorAll(CONFIG.headingTag);
    var links = [];

    texts.forEach(function(text, idx) {
      // Suche das passende DOM-Element
      var matchedH2 = null;
      allDomH2s.forEach(function(h) {
        if (h.textContent.trim() === text && !matchedH2) {
          matchedH2 = h;
        }
      });

      if (matchedH2) {
        if (!matchedH2.id) matchedH2.id = 'otp-section-' + idx;

        var a = document.createElement('a');
        a.href = '#' + matchedH2.id;
        a.textContent = text;
        a.addEventListener('click', function(e) {
          e.preventDefault();
          var target = document.getElementById(matchedH2.id);
          if (!target) return;
          var y = target.getBoundingClientRect().top
                + window.pageYOffset - CONFIG.scrollOffset;
          window.scrollTo({ top: y, behavior: 'smooth' });
          if (window.innerWidth < 768) closeFlyout();
        });
        nav.appendChild(a);
        links.push({ el: a, target: matchedH2 });
      }
    });

    return links;
  }

  // =====================================================
  //  SCROLL SPY
  // =====================================================
  function initScrollSpy(links) {
    var currentActive = null;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          for (var j = 0; j < links.length; j++) {
            if (links[j].el.getAttribute('href') === '#' + entry.target.id) {
              if (currentActive) currentActive.classList.remove('is-active');
              links[j].el.classList.add('is-active');
              currentActive = links[j].el;
              break;
            }
          }
        }
      });
    }, {
      rootMargin: '-' + CONFIG.scrollOffset + 'px 0px -60% 0px',
      threshold: 0
    });

    links.forEach(function(l) { observer.observe(l.target); });
  }

  // =====================================================
  //  FLYOUT STEUERUNG
  // =====================================================
  function openFlyout()  {
    if (flyout) flyout.classList.add('is-open');
    if (arrow) arrow.classList.add('is-open');
  }
  function closeFlyout() {
    if (flyout) flyout.classList.remove('is-open');
    if (arrow) arrow.classList.remove('is-open');
  }

  function initControls() {
    if (trigger) {
      trigger.addEventListener('click', function(e) {
        e.stopPropagation();
        flyout && flyout.classList.contains('is-open') ? closeFlyout() : openFlyout();
      });
    }
    if (closeBtn) {
      closeBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        closeFlyout();
      });
    }

    document.addEventListener('click', function(e) {
      if (widget && !widget.contains(e.target) && flyout &&
          flyout.classList.contains('is-open')) {
        closeFlyout();
      }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeFlyout();
    });

    // Scroll: Widget ein-/ausblenden
    var ticking = false;
    window.addEventListener('scroll', function() {
      if (!ticking) {
        window.requestAnimationFrame(function() {
          if (window.pageYOffset > CONFIG.showAfterPx) {
            widget.classList.add('is-visible');
          } else {
            widget.classList.remove('is-visible');
            closeFlyout();
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }

  // =====================================================
  //  INIT MIT RETRY-LOGIK
  // =====================================================
  var retryCount = 0;

  function init() {
    cacheElements();
    if (!widget || !nav) return;

    // Schritt 1: DOM-Scan
    var headings = findHeadings();

    if (headings.length >= CONFIG.minHeadings) {
      // Headings gefunden → normal aufbauen
      var links = buildNavLinks(headings);
      initScrollSpy(links);
      initControls();
      return;
    }

    // Schritt 2: Retry nach kurzer Verzögerung
    // (für den Fall, dass Elementor Widgets noch rendern)
    if (retryCount < CONFIG.maxRetries) {
      retryCount++;
      setTimeout(init, CONFIG.retryDelay);
      return;
    }

    // Schritt 3: Fetch-Fallback (Heikos Ansatz)
    if (CONFIG.useFetchFallback) {
      fetchHeadingsFromURL().then(function(texts) {
        if (texts.length >= CONFIG.minHeadings) {
          var links = buildNavFromFetchedTexts(texts);
          if (links.length >= CONFIG.minHeadings) {
            initScrollSpy(links);
            initControls();
          } else {
            widget.style.display = 'none';
          }
        } else {
          widget.style.display = 'none';
        }
      });
    } else {
      widget.style.display = 'none';
    }
  }

  // =====================================================
  //  START
  // =====================================================
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    // DOM ist bereits geladen (z.B. bei Lazy-Loaded Popups)
    init();
  }

})();
</script>				</div>
