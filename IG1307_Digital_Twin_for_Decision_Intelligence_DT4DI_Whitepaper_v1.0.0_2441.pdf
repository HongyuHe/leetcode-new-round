		<div data-particle_enable="false" data-particle-mobile-disabled="false" class="elementor-element elementor-element-4a767d3d e-flex e-con-boxed e-con e-parent" data-id="4a767d3d" data-element_type="container" data-e-type="container">
					<div class="e-con-inner">
				<div class="elementor-element elementor-element-3dafb713 elementor-widget elementor-widget-topic_line" data-id="3dafb713" data-element_type="widget" data-e-type="widget" data-widget_type="topic_line.default">
				<div class="elementor-widget-container">
					                <div class="detecon-anchor">
                    Managing Smart Manufacturing                 </div>
                <style>
                    .detecon-anchor,.detecon-no-anchor {
                        color: #E20074;
                        font-family: "TeleNeo", sans-serif;
                        font-size: 20px;
                        font-style: italic;
