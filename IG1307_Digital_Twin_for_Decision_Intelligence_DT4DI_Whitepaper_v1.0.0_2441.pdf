                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 97%;
                    opacity: 0;
                    transition: opacity 0.5s ease-in-out;
                    z-index: 1;
                    overflow: hidden;
                }

                #carousel-immersive .carousel-bg-image {
                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
