                    }
                    #carousel-immersive .carousel-immersive-title-item span .title-text{
                        font-size:16px;
                    }
                }
                @media (max-width: 768px) {
                    #carousel-immersive {
                        height: 680px;
                    }
                    #carousel-immersive .carousel-immersive-nav {
                        left: 0;
                        max-width: unset;
                        position: relative;
                        margin: 0 24px;
                        width: unset;
                        padding: 16px;
                    }
                    #carousel-immersive .carousel-immersive-bg-item {
                        height: 75%;
                    }
                    #carousel-immersive .carousel-immersive-nav h2{
                        font-size: 14px;
                    }
                    #carousel-immersive .carousel-immersive-nav h3{
                        font-size: 24px;
                        margin-bottom:24px;
                    }
                    #carousel-immersive .carousel-immersive-title-item span .title-text{
                        font-size:16px;
                    }
                }
            </style>

            <script>
                (function(){
                    const wrapper = document.getElementById("carousel-immersive");
                    if (!wrapper) return;

                    const bgItems = wrapper.querySelectorAll(".carousel-immersive-bg-item");
                    const titleItems = wrapper.querySelectorAll(".carousel-immersive-title-item");
                    const dots = wrapper.querySelectorAll(".progress-line");

                    let current = 0;
                    let interval;
                    let paused = false;

                    function activateSlide(index) {
                        current = index;
                        bgItems.forEach((el, i) => el.classList.toggle("active", i === index));
                        dots.forEach((el, i) => el.classList.toggle("active", i === index));
                        titleItems.forEach((el, i) => el.classList.toggle("active", i === index));
                    }

                    function nextSlide() {
                        if (paused) return;
                        current = (current + 1) % bgItems.length;
                        activateSlide(current);
                    }

                    function startAutoPlay() {
                        interval = setInterval(nextSlide, 5000);
                    }

                    function stopAutoPlay() {
                        paused = true;
                        clearInterval(interval);
                    }

                    function resumeAutoPlay() {
                        paused = false;
                        clearInterval(interval);
                        startAutoPlay();
                    }

                    titleItems.forEach((item) => {
                        item.addEventListener("mouseenter", function() {
                            const index = parseInt(this.dataset.index);
                            activateSlide(index);
                            stopAutoPlay();
                        });
                        item.addEventListener("mouseleave", function() {
                            resumeAutoPlay();
                        });
                    });

                    wrapper.addEventListener("mouseenter", stopAutoPlay);
                    wrapper.addEventListener("mouseleave", resumeAutoPlay);

                    activateSlide(0);
                    startAutoPlay();
                })();
            </script>
            				</div>
				</div>
