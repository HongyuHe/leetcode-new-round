                <style>
                    .elementor-dynamic-toc .toc-title {
                        color: #E20074;
                        font-family: "TeleNeo", sans-serif;
                        font-size: 20px;
                        font-style: italic;
                        font-weight: 500;
                        line-height: 120%;
                        letter-spacing: 0px;
                    }
                    .elementor-dynamic-toc .toc-list {
                        list-style: none;
                        margin: 0;
                        padding: 0;
                        margin-top: 20px;
                        font-size: 16px;
                    }

                    .elementor-dynamic-toc .toc-list li {
                        display: flex;
                        justify-content: space-between;
                        align-items: center;
                        padding-bottom: 14px;
                        padding-top: 14px;
                        margin-bottom: 0px;
                    }

                    .elementor-dynamic-toc .toc-list li a {
                        text-decoration: none;
                        flex-grow: 1;
                        color: #262933;
                    }
                    .elementor-dynamic-toc .toc-list li a:hover {
                        color: #E83390;
                    }

                    .elementor-dynamic-toc .toc-icon {
                        margin-left: 10px;
                        display: inline-flex;
                        align-items: center;
                    }

                    .elementor-dynamic-toc .toc-icon svg {
                        width: 1em;
                        height: 1em;
                        display: inline-block;
                        vertical-align: middle;
                    }
                </style>

                <script>
                    (function($){
                        const runTOCBuilder = function($scope) {
                            const tocList = $scope.find('.toc-list');
                            if (!tocList.length) return;

                            const className = tocList.data('target-class') || 'detecon-anchor';
                            const showBorder = tocList.data('show-border') === 1 || tocList.data('show-border') === '1';
                            const iconHTML = tocList.data('icon-html') || '';

                            const headings = $('.' + className);
                            tocList.empty();

                            headings.each(function(i, el) {
                                const $el = $(el);
                                let id = $el.attr('id');
                                if (!id) {
                                    const baseId = $el.text().trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
                                    id = baseId || 'toc-anchor-' + i;

                                    // Ensure uniqueness
                                    let uniqueId = id;
                                    let counter = 1;
                                    while (document.getElementById(uniqueId)) {
                                        uniqueId = id + '-' + counter++;
                                    }

                                    id = uniqueId;
                                    $el.attr('id', id);
                                }

                                const $li = $('<li></li>');
                                if (showBorder) {
                                    $li.css('border-bottom', '1px solid #AEAFB2');
                                }

                                const $a = $('<a></a>').attr('href', '#' + id).text($el.text());
                                $li.append($a);

                                if (iconHTML.trim()) {
                                    const $icon = $('<span class="toc-icon"></span>').html(iconHTML);
                                    $li.append($icon);
                                }

                                tocList.append($li);
                            });
                        };

                        $(window).on('elementor/frontend/init', function () {
                            elementorFrontend.hooks.addAction('frontend/element_ready/wd_table_of_contents.default', function($scope){
                                runTOCBuilder($scope);
                            });
                        });
                    })(jQuery);
                </script>
