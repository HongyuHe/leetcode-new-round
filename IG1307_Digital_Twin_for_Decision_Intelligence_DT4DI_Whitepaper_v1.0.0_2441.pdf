                <script>
                    (function(){
                        const wrapper = document.getElementById('custom-tabs-612b9a6');
                        if (!wrapper) return;

                        const titles = wrapper.querySelectorAll('.elementor-tab-title');
                        const contents = wrapper.querySelectorAll('.elementor-tab-content');

                        titles.forEach((title, index) => {
                            title.addEventListener('click', () => {
                                if (title.classList.contains('title-only')) return; // Prevent clicking title-only tabs

                                titles.forEach(t => t.classList.remove('elementor-active'));
                                contents.forEach(c => c.classList.remove('elementor-active'));

                                title.classList.add('elementor-active');
                                contents[index].classList.add('elementor-active');
                            });
                        });

                    })();
                </script>

                <style>

                    .elementor-tabs {
                        display: flex;
                        flex-direction: row;
                        gap: 0;
                        justify-content: space-between;
                    }

                    .elementor-tabs-wrapper {
                        display: flex;
                        flex-direction: column;
                        width: 33.33%;
                    }

                    .elementor-tab-title {
                        padding: 8px 30px 8px 16px;
                        cursor: pointer;
                        color: var(--Semantic-Colors-Text-Dark, #262933);
                        font-family: "TeleNeo";
                        font-size: 16px;
                        font-style: normal;
                        font-weight: 500;
                        line-height: 125%; /* 20px */
                        letter-spacing: var(--typography-body-M-regular-letter-spacing, 0px);
                        position: relative;
                    }
                    .elementor-tab-title::after {
                        content: "";
                        position: absolute;
                        top: 50%;
                        right: 10px;
                        transform: translateY(-50%);
                        width: 12px;
                        height: 12px;
                        background-image: url("/wp-content/uploads/2025/07/arrow-right-dark.svg");
                        background-size: contain;
                        background-repeat: no-repeat;
                    }

                    /* Make title-only links look like the static label */
                    .title-only.title-only-link {
                        display: block;
                        text-decoration: none;
                    }

                    /* Ensure the arrow is never shown for title-only (div or a) */
                    .title-only::after {
                        display: none !important;
                    }

                    .elementor-tab-title.elementor-active {
                        font-weight: 600;
                        border-right: none;
                        background: #f5f5f5;
                    }

                    .elementor-tabs-content-wrapper {
                        flex: 1;
                        background: #fff;
                        border-left: none;
                        max-width: 58.33%;
                    }

                    .elementor-tab-content {
                        display: none;
                    }

                    .elementor-tab-content.elementor-active {
                        display: block;
                        width: 100%;
                    }
                    .elementor-tab-content .elementor-button{
                        text-align: start;
                    }

                    a.title-only,
                    .title-only{
                        color: #E20074;
                        font-family: "TeleNeo", sans-serif;
                        font-size: 14px;
                        font-style: italic;
                        font-weight: 500;
                        line-height: 120%;
                        letter-spacing: 0px;
                        background: white;
                        border-bottom: none;
                        opacity: 1;
                        padding: 8px 30px 8px 16px;
                        margin-top:24px;
                    }
                    .title-only:first-of-type{
                        margin-top:0;
                    }

            @media (max-width: 768px) {
                .elementor-tabs {
                    flex-direction: column;
