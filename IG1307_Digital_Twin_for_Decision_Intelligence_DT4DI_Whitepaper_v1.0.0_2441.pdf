                                            <circle cx="2" cy="2" r="1.5" fill="#AEAFB2"/>
                                        </svg> 23.03.26 <svg xmlns="http://www.w3.org/2000/svg" width="4" height="4" viewBox="0 0 4 4" fill="none">
