                    .card-grid-experts {
                        display: grid;
                        grid-template-columns: repeat(3, 1fr);
                        gap: 32px;
                    }
                    .card-grid-expert {
                        display: flex;
                        overflow: hidden;
                        min-height: 150px;
                    }
                    .card-grid-expert .expert-image {
                        width: 150px;
                        position: relative;
                        flex-shrink: 0;
                    }
                    .card-grid-expert .expert-thumbnail-img {
                        width: 100%;
                        height: 100%;
                        object-fit: cover;
                        object-position: center;
                        display: block;
                    }
                    .card-grid-expert .expert-image button {
                        position: absolute;
                        bottom: 10px;
                        right: -10px;
                        padding: 4px 8px;
                        background: #F2F5FF;
                        border: none;
                        cursor: pointer;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                    }
                    .card-grid-expert .expert-image button svg {
                        display: block;
                        width: 16px;
                        height: 16px;
                    }
                    .card-grid-expert .expert-content {
                        padding-left: 20px;
                        flex-grow: 1;
                        display: flex;
                        flex-direction: column;
                        justify-content: flex-start;
                    }
                    .card-grid-expert .expert-content h3 {
                        font-family: "TeleNeo";
                        font-size: 20px;
                        font-style: normal;
                        font-weight: 800;
                        line-height: 125%;
                        color: #262933;
                        margin-bottom: 4px;
                        margin-top: 4px;
                    }
                    .card-grid-expert .expert-content p {
                        font-family: "TeleNeo";
                        font-size: 16px;
                        font-style: normal;
                        font-weight: 500;
                        line-height: 125%;
                        color: #262933;
                        margin-bottom: 0;
                    }
                    @media (max-width: 1440px) and (min-width: 1040px)  {
                        .card-grid-experts { grid-template-columns: repeat(2, 1fr); gap: 32px; }
                    }
                    @media (max-width: 1039px) and (min-width: 769px)  {
                        .card-grid-experts { grid-template-columns: repeat(2, 1fr); gap: 24px; }
                        .card-grid-expert .expert-content h3 { font-size: 18px; }
                        .card-grid-expert .expert-content p  { font-size: 13px; }
